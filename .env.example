# Google Gemini API Key (for prompt generation AND Nano Banana image generation)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# Image Generation Method: 'nano-banana' (uses Gemini, ~$0.10/image) or 'openai' (DALL-E 3, ~$0.04/image)
# Default: nano-banana
IMAGE_GENERATION_METHOD=nano-banana

# OpenAI API Key (only needed if using IMAGE_GENERATION_METHOD=openai)
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-key-here

# Optional: Set a custom port (default is 5001)
# PORT=5001
